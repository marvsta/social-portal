<% content_for :title, "Channels" %>
<div class="container-fluid">
  <div class="page-header">
    <div class="row">
      <div class="col-sm-6">
        <h3>Connected channels</h3>
        <p class="text-muted mb-0">Add the social accounts <%= @company.name %> publishes to.</p>
      </div>
      <div class="col-sm-6 text-end">
        <% if current_membership&.can_manage? %>
          <%= link_to new_company_social_channel_path(@company), class: "btn btn-primary" do %>
            <i data-feather="plus"></i>&nbsp; Connect channel
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @channels.empty? %>
    <div class="card">
      <div class="card-body text-center p-5">
        <i data-feather="share-2" style="width:48px;height:48px;color:#7366FF"></i>
        <h5 class="mt-3">No channels yet</h5>
        <p class="text-muted">Connect your first social account to start scheduling posts.</p>
        <% if current_membership&.can_manage? %>
          <%= link_to "Connect Instagram", new_company_social_channel_path(@company, platform: "instagram"), class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="row">
      <% @channels.each do |c| %>
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <div class="d-flex align-items-center mb-3">
                <span style="width:42px;height:42px;border-radius:8px;background:<%= c.platform_color %>;color:white;display:inline-flex;align-items:center;justify-content:center;font-weight:700;">
                  <%= c.platform_label[0] %>
                </span>
                <div class="ms-3">
                  <h6 class="mb-0"><%= c.display %></h6>
                  <small class="text-muted"><%= c.platform_label %> · <%= c.status.capitalize %></small>
                </div>
              </div>
              <% if c.platform == "instagram" %>
                <% if c.supports_auto_publish? %>
                  <span class="badge bg-success">Auto-publish ready</span>
                <% else %>
                  <span class="badge bg-warning text-dark">Auth incomplete</span>
                <% end %>
              <% else %>
                <span class="badge bg-light text-dark">Manual publish</span>
              <% end %>
              <% if current_membership&.can_manage? %>
                <div class="mt-3 d-flex gap-2">
                  <%= link_to "Edit", edit_company_social_channel_path(@company, c), class: "btn btn-sm btn-outline-secondary" %>
                  <%= button_to "Remove", company_social_channel_path(@company, c), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Remove this channel?" } } %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
