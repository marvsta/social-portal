<%= form_with model: @channel, url: form_url, local: true do |f| %>
  <% if @channel.errors.any? %>
    <div class="alert alert-danger"><%= @channel.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :platform, class: "form-label" %>
      <%= f.select :platform, SocialChannel::PLATFORMS.map { |p| [p.titleize, p] }, {}, class: "form-select", required: true %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :status, class: "form-label" %>
      <%= f.select :status, SocialChannel::STATUSES.map { |s| [s.capitalize, s] }, {}, class: "form-select" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :handle, "Handle / username", class: "form-label" %>
      <%= f.text_field :handle, class: "form-control", placeholder: "@brandhandle", required: true %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :display_name, class: "form-label" %>
      <%= f.text_field :display_name, class: "form-control", placeholder: "Brand display name" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :avatar_url, class: "form-label" %>
      <%= f.url_field :avatar_url, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :external_account_id, "Instagram Business Account ID", class: "form-label" %>
      <%= f.text_field :external_account_id, class: "form-control", placeholder: "17841... (Instagram only)" %>
    </div>
    <div class="col-12 mb-3">
      <%= f.label :access_token, "Long-lived access token", class: "form-label" %>
      <%= f.text_area :access_token, class: "form-control", rows: 3, placeholder: "Paste your Meta Graph API token (Instagram only, scoped: instagram_content_publish, instagram_basic, pages_read_engagement)" %>
      <small class="text-muted">For Instagram, this token must come from a Facebook Page connected to a Business Instagram account. See README for setup steps.</small>
    </div>
  </div>
  <%= f.submit submit_label, class: "btn btn-primary" %>
  <%= link_to "Cancel", company_social_channels_path(@company), class: "btn btn-link" %>
<% end %>
