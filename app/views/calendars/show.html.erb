<% content_for :title, "#{@company.name} · Calendar" %>
<% content_for :head do %>
  <link rel="stylesheet" type="text/css" href="/theme/css/calendar.css">
  <style>
    .fc .fc-toolbar-title { font-size: 1.25rem; font-weight: 700; }
    .fc-event { cursor: pointer; padding: 2px 4px; }
    .fc-daygrid-event { white-space: normal; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 6px; }
  </style>
<% end %>

<div class="container-fluid">
  <div class="page-header">
    <div class="row">
      <div class="col-sm-7">
        <h3>Content calendar</h3>
        <p class="text-muted mb-0">Plan, schedule, and review every post for <%= @company.name %>.</p>
      </div>
      <div class="col-sm-5 text-end">
        <% if current_membership&.can_publish? %>
          <%= link_to new_company_post_path(@company), class: "btn btn-primary" do %>
            <i data-feather="plus"></i>&nbsp; New post
          <% end %>
        <% end %>
        <%= link_to "Performance", company_dashboard_path(@company), class: "btn btn-outline-primary ms-1" %>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-xl-9 col-lg-8 mb-4">
      <div class="card">
        <div class="card-body">
          <div id="calendar"></div>
          <div class="mt-3 small">
            <% Post::STATUSES.each do |s| %>
              <% next if %w[publishing partial_failure].exclude?(s) && %w[draft pending_review approved scheduled published failed].exclude?(s) %>
              <span class="me-3">
                <span class="legend-dot" style="background: <%= Post.new(status: s).status_color %>"></span>
                <%= Post.new(status: s).status_label %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-lg-4 mb-4">
      <div class="card">
        <div class="card-header"><h5 class="mb-0">Upcoming</h5></div>
        <div class="card-body p-0">
          <% if @upcoming.empty? %>
            <p class="text-muted p-3 mb-0">Nothing scheduled.</p>
          <% else %>
            <ul class="list-group list-group-flush">
              <% @upcoming.each do |p| %>
                <li class="list-group-item">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <%= link_to (p.title.presence || p.caption.truncate(40)), company_post_path(@company, p), class: "fw-medium text-dark" %>
                      <div class="small text-muted">
                        <%= l(p.scheduled_at, format: :short) if p.scheduled_at %>
                      </div>
                    </div>
                    <span class="badge" style="background: <%= p.status_color %>; color:white;"><%= p.status_label %></span>
                  </div>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </div>

      <div class="card mt-3">
        <div class="card-header"><h5 class="mb-0">Recently published</h5></div>
        <div class="card-body p-0">
          <% if @recent_published.empty? %>
            <p class="text-muted p-3 mb-0">No published posts yet.</p>
          <% else %>
            <ul class="list-group list-group-flush">
              <% @recent_published.each do |p| %>
                <li class="list-group-item">
                  <%= link_to (p.title.presence || p.caption.truncate(40)), company_post_path(@company, p), class: "fw-medium text-dark" %>
                  <div class="small text-muted">Engagement: <%= number_with_delimiter(p.total_engagement) %></div>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for :scripts do %>
  <script src="/theme/js/calendar/moment.min.js"></script>
  <script src="/theme/js/calendar/fullcalendar.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var calEl = document.getElementById('calendar');
      if (!calEl || typeof FullCalendar === 'undefined') { return; }
      var newPostBase = "<%= new_company_post_path(@company) %>";
      var canCreatePost = <%= current_membership&.can_publish? ? "true" : "false" %>;
      var calendar = new FullCalendar.Calendar(calEl, {
        initialView: 'dayGridMonth',
        height: 'auto',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth,timeGridWeek,listWeek'
        },
        navLinks: true,
        editable: false,
        dayMaxEvents: true,
        dateClick: function(info) {
          if (!canCreatePost) { return; }
          window.location.href = newPostBase + '?scheduled_at=' + encodeURIComponent(info.dateStr + 'T09:00');
        },
        events: <%= raw @events.to_json %>
      });
      calendar.render();
    });
  </script>
<% end %>
