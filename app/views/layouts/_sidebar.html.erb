<header class="main-nav">
  <nav>
    <div class="main-navbar">
      <div id="mainnav">
        <ul class="nav-menu custom-scrollbar">
          <li class="back-btn">
            <div class="mobile-back text-end"><span>Back</span><i class="fa fa-angle-right ps-2" aria-hidden="true"></i></div>
          </li>
          <% if current_company %>
            <li class="dropdown <%= 'active' if controller_name == 'calendars' %>">
              <%= link_to company_calendar_path(current_company), class: "nav-link menu-title" do %>
                <i data-feather="calendar"></i><span>Calendar</span>
              <% end %>
            </li>
            <li class="dropdown <%= 'active' if controller_name == 'posts' %>">
              <%= link_to company_posts_path(current_company), class: "nav-link menu-title" do %>
                <i data-feather="edit-3"></i><span>Posts</span>
              <% end %>
            </li>
            <li class="dropdown <%= 'active' if controller_name == 'dashboards' %>">
              <%= link_to company_dashboard_path(current_company), class: "nav-link menu-title" do %>
                <i data-feather="bar-chart-2"></i><span>Performance</span>
              <% end %>
            </li>
            <li class="dropdown <%= 'active' if controller_name == 'social_channels' %>">
              <%= link_to company_social_channels_path(current_company), class: "nav-link menu-title" do %>
                <i data-feather="share-2"></i><span>Channels</span>
              <% end %>
            </li>
            <% if current_membership&.can_manage? %>
              <li class="dropdown <%= 'active' if controller_name == 'companies' && action_name == 'edit' %>">
                <%= link_to edit_company_path(current_company), class: "nav-link menu-title" do %>
                  <i data-feather="settings"></i><span>Company</span>
                <% end %>
              </li>
            <% end %>
          <% else %>
            <li class="dropdown <%= 'active' if controller_name == 'companies' %>">
              <%= link_to companies_path, class: "nav-link menu-title" do %>
                <i data-feather="briefcase"></i><span>Companies</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>
</header>
