<%= form_with model: @company, url: form_url, local: true do |f| %>
  <% if @company.errors.any? %>
    <div class="alert alert-danger"><%= @company.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :slug, class: "form-label" %>
      <%= f.text_field :slug, class: "form-control", placeholder: "Auto-generated from name" %>
      <small class="text-muted">Used in URLs. Lowercase letters, numbers, dashes.</small>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :website, class: "form-label" %>
      <%= f.url_field :website, class: "form-control", placeholder: "https://" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :timezone, class: "form-label" %>
      <%= f.select :timezone, ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.name] }, {}, class: "form-select" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :logo_url, class: "form-label" %>
      <%= f.url_field :logo_url, class: "form-control", placeholder: "https://..." %>
    </div>
    <div class="col-12 mb-3">
      <%= f.label :description, class: "form-label" %>
      <%= f.text_area :description, class: "form-control", rows: 3 %>
    </div>
  </div>
  <%= f.submit submit_label, class: "btn btn-primary" %>
<% end %>
