<% content_for :title, "Create account" %>
<%= form_with model: @user, url: signup_path, local: true, data: { turbo: false } do |f| %>
  <h4>Create your account</h4>
  <p>Plan, schedule, and track your social posts.</p>

  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <%= @user.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="form-group mb-3">
    <label class="col-form-label">Full name</label>
    <%= f.text_field :name, class: "form-control", autofocus: true %>
  </div>
  <div class="form-group mb-3">
    <label class="col-form-label">Email</label>
    <%= f.email_field :email, class: "form-control", required: true %>
  </div>
  <div class="form-group mb-3">
    <label class="col-form-label">Password</label>
    <%= f.password_field :password, class: "form-control", required: true %>
    <small class="text-muted">At least 8 characters.</small>
  </div>
  <div class="form-group mb-3">
    <label class="col-form-label">Confirm password</label>
    <%= f.password_field :password_confirmation, class: "form-control", required: true %>
  </div>
  <div class="form-group mb-0">
    <%= f.submit "Create account", class: "btn btn-primary btn-block w-100" %>
  </div>
  <p class="mt-4 mb-0">Already have an account? <%= link_to "Sign in", login_path %></p>
<% end %>
